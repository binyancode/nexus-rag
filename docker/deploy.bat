REM 0. Login and select subscription.
az login
az account set --subscription "ME-MngEnvMCAP036409-binyan-1"

REM 1A. New app only: create a sidecar-enabled Linux Web App. Skip if it already exists.
REM IMPORTANT: Do not add --domain-name-scope. Omitting it keeps Secure Unique Default Hostname disabled.
REM Expected hostname: binyan-nexus-rag-api.azurewebsites.net (no hash and no regional suffix).
az webapp create --name "binyan-nexus-rag-api" --resource-group "web" --plan "ASP-web-a6cc" --sitecontainers-app --tags "SecurityControl=Ignore"

REM 1B. Check mode first. Run convert ONLY when output starts with DOCKER| or COMPOSE|.
REM If output is SITECONTAINERS, skip convert and continue with sitecontainers list/update.
az webapp config show --name "binyan-nexus-rag-api" --resource-group "web" --query linuxFxVersion --output tsv
az webapp sitecontainers convert --mode sitecontainers --name "binyan-nexus-rag-api" --resource-group "web" --yes

REM 2. Enable the Web App system-assigned identity and copy the principalId output.
az webapp identity assign --name "binyan-nexus-rag-api" --resource-group "web" --query principalId --output tsv

REM 3. Copy the ACR resource ID output.
az acr show --name "binyancontainerea" --query id --output tsv

REM 4. Replace the two placeholders with outputs from steps 2 and 3.
az role assignment create --assignee-object-id "98074a3c-50c0-4886-8579-fedf652cad02" --assignee-principal-type ServicePrincipal --role "AcrPull" --scope "/subscriptions/4714cf53-6250-494e-915b-7889ff9caa2e/resourceGroups/container/providers/Microsoft.ContainerRegistry/registries/binyancontainerea"

REM 5. Inspect containers. If "main" exists use update; otherwise use create.
az webapp sitecontainers list --name "binyan-nexus-rag-api" --resource-group "web" --output table

REM 5A. Run only when the main container does not exist.
az webapp sitecontainers create --name "binyan-nexus-rag-api" --resource-group "web" --container-name "main" --image "binyancontainerea.azurecr.io/nexusrag-api:latest" --target-port 8000 --is-main true --system-assigned-identity true

REM 5B. Existing converted app / future deployments: update its main container.
az webapp sitecontainers update --name "binyan-nexus-rag-api" --resource-group "web" --container-name "main" --image "binyancontainerea.azurecr.io/nexusrag-api:latest" --target-port 8000 --is-main true --system-assigned-identity true

REM 8. Enable HTTPS and merge/update the requested resource tag.
az webapp update --name "binyan-nexus-rag-api" --resource-group "web" --https-only true --set tags.SecurityControl=Ignore

REM 9. Restart and display the URL.
az webapp restart --name "binyan-nexus-rag-api" --resource-group "web"
az webapp show --name "binyan-nexus-rag-api" --resource-group "web" --query "{defaultHostName:defaultHostName,domainNameScope:autoGeneratedDomainNameLabelScope}" --output table


REM ============================================================================
REM Frontend Web App: binyan-nexus-rag
REM Image: binyancontainerea.azurecr.io/nexusrag-server:latest
REM IMPORTANT: Do not add --domain-name-scope. Omitting it keeps Secure Unique Default Hostname disabled.
REM Expected hostname: binyan-nexus-rag.azurewebsites.net
REM ============================================================================

REM 10A. New app only: create a sidecar-enabled frontend Web App. Skip if it already exists.
az webapp create --name "binyan-nexus-rag" --resource-group "web" --plan "ASP-web-a6cc" --sitecontainers-app --tags "SecurityControl=Ignore"

REM 10B. Check mode first. Run convert ONLY when output starts with DOCKER| or COMPOSE|.
REM Current binyan-nexus-rag is already SITECONTAINERS, so skip the convert line below.
az webapp config show --name "binyan-nexus-rag" --resource-group "web" --query linuxFxVersion --output tsv
az webapp sitecontainers convert --mode sitecontainers --name "binyan-nexus-rag" --resource-group "web" --yes

REM 11. Enable its system-assigned identity and copy the principalId output.
az webapp identity assign --name "binyan-nexus-rag" --resource-group "web" --query principalId --output tsv

REM 12. Use the ACR resource ID from step 3. Replace the frontend principal ID placeholder.
az role assignment create --assignee-object-id "12c1655e-3f03-4784-bfbf-3f5752cf226a" --assignee-principal-type ServicePrincipal --role "AcrPull" --scope "/subscriptions/4714cf53-6250-494e-915b-7889ff9caa2e/resourceGroups/container/providers/Microsoft.ContainerRegistry/registries/binyancontainerea"

REM 13. Inspect containers. If "main" exists use update; otherwise use create.
az webapp sitecontainers list --name "binyan-nexus-rag" --resource-group "web" --output table

REM 13A. Run only when the main container does not exist.
az webapp sitecontainers create --name "binyan-nexus-rag" --resource-group "web" --container-name "main" --image "binyancontainerea.azurecr.io/nexusrag-server:latest" --target-port 8080 --is-main true --system-assigned-identity true

REM 13B. Existing converted app / future deployments: update its main container.
az webapp sitecontainers update --name "binyan-nexus-rag" --resource-group "web" --container-name "main" --image "binyancontainerea.azurecr.io/nexusrag-server:latest" --target-port 8080 --is-main true --system-assigned-identity true

REM 15. Configure the Python backend URL. Port is defined on the main sitecontainer.
az webapp config appsettings set --name "binyan-nexus-rag" --resource-group "web" --settings "BackendAPI__BaseUrl=https://binyan-nexus-rag-api.azurewebsites.net/api" "BackendAPI__Version=v1"

REM 16. Enable HTTPS and merge/update the requested resource tag.
az webapp update --name "binyan-nexus-rag" --resource-group "web" --https-only true --set tags.SecurityControl=Ignore

REM 17. Restart and verify the frontend hostname and domain scope.
az webapp restart --name "binyan-nexus-rag" --resource-group "web"
az webapp show --name "binyan-nexus-rag" --resource-group "web" --query "{defaultHostName:defaultHostName,domainNameScope:autoGeneratedDomainNameLabelScope}" --output table
